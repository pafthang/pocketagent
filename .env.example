# Copy to .env for docker compose overrides

# development | production (production enables rate limits + strong secret policy)
APP_ENV=development

LOG_LEVEL=info
EMBED_MODEL=nomic-embed-text

NATS_URL=nats://nats:4222
# NATS monitoring (varz, connz, healthz) — embedded server HTTP port
NATS_HTTP_URL=http://127.0.0.1:8222

# OpenTelemetry (optional; traces exported when endpoint is set)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_SERVICE_NAME=pocketagent-gate
OLLAMA_URL=http://ollama:11434
POCKETBASE_URL=http://pocket:8090
MEMO_URL=http://memo:8082
MEMO_SERVICE_TOKEN=dev-memo-token
MEMO_DATA_DIR=data/memo
SPACE_URL=http://space:8083
PUBLIC_BASE_URL=http://127.0.0.1:8080
REQUIRE_EMAIL_VERIFICATION=false

# Pocket service bootstrap (cmd/pocket only): creates user + superuser + admin space on first start
POCKETBASE_SUPERUSER_EMAIL=admin@example.com
POCKETBASE_SUPERUSER_PASSWORD=changeme123

# Backend PocketBase admin client (gate/agent/space/exec/task): API auth for CRUD and workers.
# In docker-compose ADMIN_* falls back to SUPERUSER_* when unset; values may match in dev.
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=changeme123

# Rate limits (auto-enabled when APP_ENV=production); optional overrides
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=120
# AUTH_RATE_LIMIT_PER_MINUTE=10

# Exec tools (search, code_exec, MCP)
# SEARCH_PROVIDER=auto   # auto | serper | tavily | duckduckgo
# SERPER_API_KEY=
# TAVILY_API_KEY=
# CODE_EXEC_ENABLED=false
# CODE_EXEC_TIMEOUT_SEC=10
# MCP_SERVERS=[{"name":"fs","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}]

# Security
# PROMPT_GUARD_ENABLED=true
# PROMPT_GUARD_MODE=block   # block | warn (default: block in prod, warn in dev)
# PROMPT_MAX_LENGTH=32000
# EGRESS_ALLOWLIST=api.duckduckgo.com,google.serper.dev,api.tavily.com,ollama,pocket,memo
# EGRESS_ALLOWLIST_ENABLED=true
